<!DOCTYPE html>
<html>
<head>
    <title>All Products</title>
</head>
<body>

<h1>All Products</h1>

<a href="/product/form">Add Product</a>

<% data.forEach(p => { %>

    <div>
        <h3><%= p.name %></h3>

        <img src="<%= p.img %>" height="200" width="200">

        <p>Price: ₹ <%= p.price %></p>

        <a href="/products/<%= p._id %>">View</a>
        <a href="/product/<%= p._id %>/edit">Edit</a>

        <form action="/product/<%= p._id %>?_method=DELETE" method="POST">
            <button>Delete</button>
        </form>

        <hr>
    </div>

<% }) %>

</body>
</html>